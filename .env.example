# =====================================================================
# Database (Supabase Postgres)
# ---------------------------------------------------------------------
# Ambil dari: Supabase Dashboard → Project → Connect → ORMs / "Connection string"
# Gunakan "Session pooler" (host: ...pooler.supabase.com, port 5432).
# Ganti [YOUR-PASSWORD] dengan password database project kamu.
#
# Contoh format:
# DATABASE_URL="postgresql://postgres.abcdefghijklmno:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"
# =====================================================================
DATABASE_URL=""

# =====================================================================
# Supabase Storage (untuk upload & tampilkan bukti pembayaran)
# ---------------------------------------------------------------------
# 1. Supabase Dashboard → Storage → buat bucket bernama "payment-proofs"
#    (biarkan Private — app membuat signed URL otomatis).
# 2. Ambil dari: Settings → API
#    - SUPABASE_URL = "Project URL", FORMAT: https://<project-ref>.supabase.co
#      ⚠ BUKAN URL dashboard (https://supabase.com/dashboard/project/<ref>) !
#    - SUPABASE_SERVICE_ROLE_KEY = "service_role" secret (JANGAN diekspos ke client)
# =====================================================================
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""

# =====================================================================
# WhatsApp Gateway (notifikasi otomatis)
# ---------------------------------------------------------------------
# API key project dari wa-gateway.dokterkoding.my.id (header X-API-Key).
# Kalau kosong, notifikasi WA otomatis di-skip (pendaftaran tetap jalan).
# =====================================================================
WA_API_KEY=""
